{% extends "_layouts/base.twig" %}

{% set title = "Application Received" %}

{% block content %}
<div class="max-w-2xl mx-auto mt-8 mb-16 px-4 sm:px-6">
    <div class="bg-white rounded-lg shadow-md p-8 text-center">

        <div class="mb-6">
            <div class="mx-auto w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            <h1 class="text-3xl font-bold text-gray-900 mb-2">Application Received!</h1>
            <p class="text-lg text-gray-600">Thanks for signing up — we're excited to have you on {{ siteName }}.</p>
        </div>

        {# Step 1: Verify email #}
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 mb-4 text-left">
            <div class="flex items-start">
                <div class="flex-shrink-0 mt-0.5">
                    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-amber-500 text-white text-xs font-bold">1</span>
                </div>
                <div class="ml-4">
                    <h2 class="text-base font-semibold text-amber-900 mb-1">Verify your email address</h2>
                    <p class="text-amber-800 text-sm">We've sent a confirmation link to your email. Please click it to verify your address — check your inbox and spam folder.</p>
                </div>
            </div>
        </div>

        {# Step 2: Await approval #}
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-8 text-left">
            <div class="flex items-start">
                <div class="flex-shrink-0 mt-0.5">
                    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-blue-500 text-white text-xs font-bold">2</span>
                </div>
                <div class="ml-4">
                    <h2 class="text-base font-semibold text-blue-900 mb-1">We'll review your listing</h2>
                    <p class="text-blue-800 text-sm">Once your email is verified, our team will review your business listing. <strong>We'll notify you by email when your listing is approved and live</strong> on the site — usually within 1–2 business days.</p>
                </div>
            </div>
        </div>

        <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-8">
            <div class="flex items-center justify-center mb-1">
                <svg class="w-4 h-4 text-green-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <p class="text-green-900 font-semibold text-sm">Listing on {{ siteName }} is always FREE</p>
            </div>
            <p class="text-green-800 text-sm">No monthly fees, setup costs, or hidden charges — ever.</p>
        </div>

        <div class="pt-4 border-t border-gray-200">
            <a href="/" class="text-gray-500 hover:text-gray-700 transition-colors text-sm">
                ← Back to Home
            </a>
        </div>

    </div>
</div>
{% endblock %}
