{% extends "_layouts/base.twig" %}

{% block title %}{{ entry.title }} - {{ parent() }}{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto min-h-screen px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <!-- Business Header -->
    <div class="bg-gray-900 border border-gray-800 rounded-lg shadow-xl shadow-black/20 overflow-hidden">
        <!-- Hero Image Section -->
        {% if entry.businessImages|length %}
            <div class="h-64 md:h-96 relative bg-gray-800">
                {% set firstImage = entry.businessImages[0] %}
                <img src="{{ firstImage.url }}" alt="{{ firstImage.title ?: entry.title }}" class="w-full h-full object-cover business-hero-image" width="800" height="384" loading="eager" style="aspect-ratio: 800/384;">
                <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-gray-950/80 to-transparent"></div>
            </div>
        {% else %}
            <!-- Placeholder if no images -->
            <div class="h-64 md:h-96 bg-gray-800 flex items-center justify-center">
                <div class="text-center">
                    <svg class="mx-auto h-12 w-12 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <p class="mt-2 text-gray-500">No images available</p>
                </div>
            </div>
        {% endif %}

        <!-- Business Information -->
        <div class="p-5 sm:p-6 md:p-8 lg:p-10">
            <h1 class="text-3xl md:text-4xl font-bold text-gray-100 mb-4">{{ entry.title }}</h1>

            <!-- Category & Contact Buttons -->
            <div class="flex flex-wrap gap-2 mb-8">
                {% set businessCategories = entry.category.all() %}
                {% if businessCategories|length > 0 %}
                    {% for category in businessCategories %}
                        <a href="/category/{{ category.slug }}" class="inline-flex items-center px-3 py-1.5 text-sm font-medium bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors ring-1 ring-blue-400/30">
                            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                            </svg>
                            {{ category.title }}
                        </a>
                    {% endfor %}
                {% endif %}

                {% if attribute(entry, 'businessPhone')|length %}
                    <a href="{{ attribute(entry, 'businessPhone') }}" class="inline-flex items-center px-3 py-1.5 text-sm font-medium bg-gray-800 text-gray-200 rounded-md hover:bg-gray-700 hover:text-white transition-colors ring-1 ring-gray-700">
                        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                        </svg>
                        {{ attribute(entry, 'businessPhone') }}
                    </a>
                {% endif %}

                {% if attribute(entry, 'businessWebsite')|length %}
                    <a href="{{ attribute(entry, 'businessWebsite') }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-3 py-1.5 text-sm font-medium bg-gray-800 text-gray-200 rounded-md hover:bg-gray-700 hover:text-white transition-colors ring-1 ring-gray-700">
                        Visit Site
                        <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                        </svg>
                    </a>
                {% endif %}
            </div>

            <!-- Contact Information Grid -->
            <div class="grid md:grid-cols-12 gap-6 lg:gap-8">
                <!-- Left Column -->
                <div class="space-y-6 md:col-span-7">
                    <!-- Business Description -->
                    {% if entry.businessDescription|length %}
                        <div class="prose prose-invert max-w-none prose-p:text-gray-300 prose-a:text-blue-400 prose-strong:text-gray-100">
                            {{ entry.businessDescription|raw }}
                        </div>
                    {% endif %}
                </div>

                <!-- Right Column -->
                <div class="space-y-6 md:col-span-5">
                    <!-- Address -->
                    {% set businessAddress = entry.businessAddress.one() %}
                    {% if businessAddress %}
                        <div class="flex items-start rounded-lg border border-gray-800 bg-gray-950/50 p-4">
                            <svg class="w-5 h-5 text-blue-400 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                            <span class="text-gray-200 font-medium leading-relaxed">
                                {{ businessAddress.addressLine1 }}{% if businessAddress.addressLine2 %}<br>{{ businessAddress.addressLine2 }}{% endif %}<br>{{ businessAddress.locality }}, {{ businessAddress.administrativeArea }} {{ businessAddress.postalCode }}
                            </span>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Special Offer -->
                {% if entry.oneSpecial|length %}
                    {# Check if oneSpecial has been redeemed this month #}
                    {% set currentMonth = 'now'|date('n') - 1 %}
                    {% set oneSpecialRedeemed = false %}
                    {% if currentUser %}
                        {% set oneSpecialToken = craft.app.db.createCommand("
                            SELECT usedAt
                            FROM {{%redeem_tokens}}
                            WHERE userId = :userId
                            AND businessId = :businessId
                            AND redeemType = 'oneSpecial'
                            AND monthIndex = :currentMonth
                            AND usedAt IS NOT NULL
                            LIMIT 1
                        ")
                        .bindValue(':userId', currentUser.id)
                        .bindValue(':businessId', entry.id)
                        .bindValue(':currentMonth', currentMonth)
                        .queryOne() %}
                        {% set oneSpecialRedeemed = oneSpecialToken ? true : false %}
                    {% endif %}

                    <div class="mt-8 rounded-lg border border-green-500/30 bg-green-500/10 p-5">
                        <div class="flex items-start space-x-3">
                            <svg class="w-6 h-6 text-green-300 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"></path>
                            </svg>
                            <div class="w-full">
                                <h3 class="font-semibold text-green-200 mb-2">Member Only Specials!</h3>
                                <div class="flex flex-col gap-2">
                                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                                        <p class="text-gray-100 leading-relaxed">{{ entry.oneSpecial }}</p>
                                        {% if currentUser %}
                                            {% if oneSpecialRedeemed %}
                                                <button disabled class="inline-flex items-center px-3 py-1 text-sm font-medium bg-gray-700 text-gray-300 rounded-md cursor-not-allowed opacity-70 sm:ml-4" title="Already redeemed this month">
                                                    Redeemed
                                                </button>
                                            {% else %}
                                                <form method="post" class="inline-block sm:ml-4" data-redeem-form>
                                                {{ csrfInput({ async: true }) }}
                                                {{ actionInput('redeem/default/generate-redeem-token') }}
                                                {{ redirectInput(entry.url) }}
                                                <input type="hidden" name="businessId" value="{{ entry.id }}">
                                                <input type="hidden" name="redeemType" value="oneSpecial">
                                                <input type="hidden" name="monthIndex" value="{{ currentMonth }}">
                                                <button type="submit" class="inline-flex items-center px-3 py-1 text-sm font-medium bg-green-600 text-white rounded-md hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                                                    Redeem
                                                </button>
                                            </form>
                                        {% endif %}
                                    {% else %}
                                        <a href="/register" class="inline-flex items-center px-3 py-1 text-sm font-medium bg-red-600 text-white rounded-md hover:bg-red-700 transition-colors sm:ml-4">
                                            Sign Up to Redeem
                                        </a>
                                    {% endif %}
                                    </div>
                                    {% if currentUser and oneSpecialRedeemed %}
                                        {% set nextMonth = ('now'|date_modify('+1 month'))|date('F') %}
                                        <p class="text-sm text-gray-400 italic">Available again in {{ nextMonth }}</p>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}

            <!-- Monthly Specials -->
            {% set validMonthlySpecials = [] %}
            {% for row in entry.monthlySpecials %}
                {% if row.month|length and row.special|length %}
                    {% set validMonthlySpecials = validMonthlySpecials|merge([row]) %}
                {% endif %}
            {% endfor %}

            {% if validMonthlySpecials|length %}
                {% set allSame = true %}
                {% set firstSpecial = validMonthlySpecials[0].special %}
                {% for row in validMonthlySpecials %}
                    {% if row.special != firstSpecial %}
                        {% set allSame = false %}
                    {% endif %}
                {% endfor %}

                {# Get user's redeemed monthly tokens for this business #}
                {% set redeemedMonths = {} %}
                {% if currentUser %}
                    {% set userRedeemedTokens = craft.app.db.createCommand("
                        SELECT monthIndex, usedAt
                        FROM {{%redeem_tokens}}
                        WHERE userId = :userId
                        AND businessId = :businessId
                        AND redeemType = 'monthlySpecial'
                    ")
                    .bindValue(':userId', currentUser.id)
                    .bindValue(':businessId', entry.id)
                    .queryAll() %}

                    {% for token in userRedeemedTokens %}
                        {% set key = 'month_' ~ token.monthIndex %}
                        {% set redeemedMonths = redeemedMonths|merge({(key): token.usedAt}) %}
                    {% endfor %}
                {% endif %}



                {% set months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'] %}

                {# Get current month for time-based availability #}
                {% set currentMonthIndex = 'now'|date('n') - 1 %}

                <div class="mt-8 mb-20 rounded-lg border border-gray-800 bg-gray-950/40 p-5">
                    <div class="flex items-start space-x-3 mb-4">
                        <svg class="w-6 h-6 text-green-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"></path>
                        </svg>
                        <h3 class="font-semibold text-gray-100">Member Only Monthly Specials</h3>
                    </div>
                    <div class="overflow-x-auto rounded-lg border border-gray-800">
                        <table class="w-full min-w-[72rem] divide-y divide-gray-800">
                            <colgroup>
                                <col class="w-36">
                                <col>
                                <col class="w-44">
                            </colgroup>
                            <thead class="bg-gray-800">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Month</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Special</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-400 uppercase tracking-wider">Action</th>
                                </tr>
                            </thead>
                            <tbody class="bg-gray-900 divide-y divide-gray-800">
                                {% for month in months %}
                                    {% set monthIndex = loop.index0 %}
                                    {% set monthData = validMonthlySpecials[monthIndex] ?? null %}
                                    {% if allSame %}
                                        {% set displaySpecial = firstSpecial %}
                                    {% else %}
                                        {% set displaySpecial = monthData ? monthData.special : firstSpecial %}
                                    {% endif %}
                                    {% set isRedeemed = redeemedMonths['month_' ~ monthIndex] is defined %}
                                    {% set isFutureMonth = monthIndex > currentMonthIndex %}
                                    {% set isPastMonth = monthIndex < currentMonthIndex %}
                                    <tr class="{% if loop.index is odd %}bg-gray-900{% else %}bg-gray-950/40{% endif %} {% if isRedeemed or isFutureMonth %}opacity-60{% endif %}">
                                        <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-100">{{ month }}</td>
                                        <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-200">
                                            {{ displaySpecial }}
                                            {% if isRedeemed %}
                                                <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-800 text-gray-300 ring-1 ring-gray-700">
                                                    <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                                    </svg>
                                                    Redeemed
                                                </span>
                                            {% endif %}
                                        </td>
                                        <td class="px-4 py-3 whitespace-nowrap text-right text-sm">
                                            {% if currentUser %}
                                                {% if isRedeemed %}
                                                    <button disabled class="inline-flex items-center px-3 py-1 text-sm font-medium bg-gray-400 text-white rounded-md cursor-not-allowed opacity-50" title="Already redeemed on {{ redeemedMonths['month_' ~ monthIndex]|date('M j, Y') }}">
                                                        Redeemed
                                                    </button>
                                                {% elseif isFutureMonth %}
                                                    <button disabled class="inline-flex items-center px-3 py-1 text-sm font-medium bg-blue-600 text-white rounded-md cursor-not-allowed opacity-75" title="Available in {{ month }}">
                                                        Available {{ month }}
                                                    </button>
                                                {% elseif isPastMonth %}
                                                    <button disabled class="inline-flex items-center px-3 py-1 text-sm font-medium bg-gray-700 text-gray-300 rounded-md cursor-not-allowed opacity-70" title="Expired - not redeemed in {{ month }}">
                                                        Expired
                                                    </button>
                                                {% else %}
                                                    <form method="post" class="inline-block" data-redeem-form>
                                                        {{ csrfInput({ async: true }) }}
                                                        {{ actionInput('redeem/default/generate-redeem-token') }}
                                                        {{ redirectInput(entry.url) }}
                                                        <input type="hidden" name="businessId" value="{{ entry.id }}">
                                                        <input type="hidden" name="redeemType" value="monthlySpecial">
                                                        <input type="hidden" name="monthIndex" value="{{ monthIndex }}">
                                                        <input type="hidden" name="monthData" value="{{ month ~ '|' ~ displaySpecial }}">
                                                        <button type="submit" class="inline-flex items-center px-3 py-1 text-sm font-medium bg-green-600 text-white rounded-md hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                                                            Redeem
                                                        </button>
                                                    </form>
                                                {% endif %}
                                            {% else %}
                                                <a href="/register" class="inline-flex items-center px-3 py-1 text-sm font-medium bg-red-600 text-white rounded-md hover:bg-red-700 transition-colors">
                                                    Sign Up
                                                </a>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endif %}

            <!-- Pagination -->
            {% set currentCategory = entry.category.one() %}
            {% set prevEntry = null %}
            {% set nextEntry = null %}

            {% if currentCategory %}
                {% set prevEntry = craft.entries()
                    .section('business')
                    .relatedTo(currentCategory)
                    .id('< ' ~ entry.id)
                    .orderBy('id desc')
                    .one() %}

                {% set nextEntry = craft.entries()
                    .section('business')
                    .relatedTo(currentCategory)
                    .id('> ' ~ entry.id)
                    .orderBy('id asc')
                    .one() %}
            {% endif %}

            <div class="mt-8 pt-6 border-t border-gray-800">
                <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-3">
                    <div class="flex-1">
                        {% if prevEntry %}
                            <a href="{{ prevEntry.url }}" class="inline-flex items-center text-blue-400 hover:text-blue-300 transition-colors">
                                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                                </svg>
                                <span class="hidden sm:inline">Previous: </span>{{ prevEntry.title }}
                            </a>
                        {% endif %}
                    </div>

                    <div class="flex-shrink-0 sm:mx-4">
                        <a href="/business" class="inline-flex items-center text-gray-300 hover:text-white transition-colors">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                            </svg>
                            All Businesses
                        </a>
                    </div>

                    <div class="flex-1 text-right">
                        {% if nextEntry %}
                            <a href="{{ nextEntry.url }}" class="inline-flex items-center text-blue-400 hover:text-blue-300 transition-colors">
                                <span class="hidden sm:inline">Next: </span>{{ nextEntry.title }}
                                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                </svg>
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
/* Prevent layout shifts during image loading */
img {
    max-width: 100%;
    height: auto;
}

/* Ensure consistent spacing */
.business-hero-image {
    min-height: 16rem; /* h-64 */
}

@media (min-width: 768px) {
    .business-hero-image {
        min-height: 24rem; /* md:h-96 */
    }
}


</style>

<script>
// Enhance redeem form submissions
document.addEventListener('DOMContentLoaded', function() {
    const redeemForms = document.querySelectorAll('form[data-redeem-form]');

    redeemForms.forEach(form => {
        form.addEventListener('submit', function(e) {
            const button = form.querySelector('button[type="submit"]');

            // Disable button to prevent double submission
            if (button) {
                button.disabled = true;
                button.innerHTML = '<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Generating...';

                // Re-enable button after 5 seconds in case of error
                setTimeout(() => {
                    button.disabled = false;
                    button.innerHTML = 'Redeem';
                }, 5000);
            }
        });
    });
});
</script>
{% endblock %}
