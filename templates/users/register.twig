{% extends "_layouts/base.twig" %}

{% set title = "Create Account" %}

{% block content %}
<div class="max-w-2xl lg:max-w-4xl xl:max-w-5xl mx-auto mt-8 mb-16 px-4">
	<div class="bg-gray-900 rounded-lg shadow-md p-8 border border-gray-800">


		<div class="bg-gray-800/50 border border-gray-700 rounded-lg p-6 md:p-10 mb-10 text-gray-200 text-base md:text-lg lg:text-xl leading-loose">

			<h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-green-400 mb-6">Welcome to Gifts Around</h2>
			<p class="mb-6 leading-8">Gifts Around is your local-first membership for discovering and redeeming exclusive monthly specials from businesses right in your community — food &amp; beverage, retail, entertainment, health &amp; beauty, and services.</p>

			{% set latestBusinesses = craft.entries().section('business').orderBy('postDate DESC').limit(6).all() %}
			{% if latestBusinesses|length %}
				<div class="mb-8">
					<p class="text-xs md:text-sm uppercase tracking-wider font-semibold text-green-400 mb-3">Recently Added Businesses</p>
					<div class="grid gap-3 sm:grid-cols-2">
						{% for business in latestBusinesses %}
							<a href="{{ business.url }}" class="flex items-center gap-3 bg-gray-900/60 border border-gray-700 rounded-lg p-2 hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-200">
								<div class="w-14 h-14 rounded-md overflow-hidden bg-gray-700 flex-shrink-0">
									{% set businessImage = business.businessImages.one() %}
									{% if businessImage %}
										<img src="{{ businessImage.url }}" alt="{{ businessImage.title ?: business.title }}" class="w-full h-full object-cover">
									{% else %}
										<div class="w-full h-full flex items-center justify-center text-gray-500">
											<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
										</div>
									{% endif %}
								</div>
								<div class="min-w-0">
									<p class="text-sm md:text-base font-semibold text-gray-100 leading-tight truncate">{{ business.title }}</p>
									{% set businessCategories = business.category.all() %}
									{% if businessCategories|length %}
										<p class="text-xs text-blue-300 truncate">{{ businessCategories|map(c => c.title)|join(', ') }}</p>
									{% endif %}
								</div>
							</a>
						{% endfor %}
					</div>
					<p class="text-sm mt-3"><a href="/business" class="text-blue-400 hover:text-blue-300 underline-offset-4 hover:underline transition-colors">Browse all businesses &rarr;</a></p>
				</div>
			{% endif %}

			<p class="mb-6 leading-loose"><span class="inline-block bg-green-500/10 text-green-300 text-xs md:text-sm font-semibold uppercase tracking-wide px-3 py-2 rounded mr-2 align-middle mb-2">Introductory Pricing</span><br>Join now for <span class="line-through text-gray-500 font-semibold">$19.99/year</span> <strong class="text-green-400">$9.99/year</strong>.<br>Business accounts are always <strong class="text-green-400">free</strong>.<br>Sign up today and start saving on the local experiences you already love.</p>
			<hr class="border-gray-700 mb-8">
			<h2 class="text-base md:text-lg font-semibold text-green-400 mb-4">How it works</h2>
			<ol class="list-decimal list-inside space-y-3 text-base md:text-lg leading-relaxed">
				<li>Fill out the form below to create your account.</li>
				<li>Check your email for a verification link and click it to activate your account.</li>
				<li>Once activated, you'll be signed in and taken to your account page.</li>
				<li>Start redeeming local specials from businesses near you for just <span class="line-through text-gray-500 font-semibold">$19.99/year</span> <strong class="text-green-400">$9.99/year</strong> (introductory pricing).</li>
			</ol>
		</div>

		{# Freeform form with custom dark theme styling #}
		{{ freeform.form('userRegistration').render({
			formattingTemplate: 'user-registration.twig',
			returnUrl: '/account',
		}) }}

		<div class="mt-6 text-center">
			<p class="text-gray-400">Already have an account? <a href="/login" class="text-blue-400 hover:text-blue-300 font-medium">Sign in</a></p>
		</div>
	</div>
</div>
{% endblock %}
