{% extends "_layouts/base.twig" %}

{% set title = "Create Account" %}

{% block content %}
<div class="max-w-2xl lg:max-w-4xl xl:max-w-5xl mx-auto mt-8 mb-16 px-4">
	<div class="bg-gray-900 rounded-lg shadow-md p-8 border border-gray-800">


		<div class="bg-gray-800/50 border border-gray-700 rounded-lg p-6 md:p-8 mb-8 text-gray-200 text-base md:text-lg lg:text-xl leading-relaxed">

			<h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-green-400 mb-4">Welcome to Gifts Around</h2>
			<p class="mb-3">Gifts Around is your local-first membership for discovering and redeeming exclusive monthly specials from businesses right in your community — food &amp; beverage, retail, entertainment, health &amp; beauty, and services.</p>
			<p class="mb-3"><span class="inline-block bg-green-500/10 text-green-300 text-xs md:text-sm font-semibold uppercase tracking-wide px-3 py-2 rounded mr-2 align-middle mb-2">Introductory Pricing</span><br>Join now for <span class="line-through text-gray-500 font-semibold">$19.99/year</span> <strong class="text-green-400">$9.99/year</strong>.<br>Business accounts are always <strong class="text-green-400">free</strong>.
		<br>Sign up today and start saving on the local experiences you already love.</p>
			<hr class="border-gray-700 mb-6">
			<h2 class="text-xl md:text-2xl lg:text-3xl font-semibold text-green-400 mb-4">How it works</h2>
			<ol class="list-decimal list-inside space-y-2">
				<li>Fill out the form below to create your account.</li>
				<li>Check your email for a verification link and click it to activate your account.</li>
				<li>Once activated, you'll be signed in and taken to your account page.</li>
				<li>Start redeeming local specials from businesses near you for just <span class="line-through text-gray-500 font-semibold">$19.99/year</span> <strong class="text-green-400">$9.99/year</strong> (introductory pricing).</li>
			</ol>
		</div>

		{# Freeform form with custom dark theme styling #}
		{{ freeform.form('userRegistration').render({
			returnUrl: '/account',
			attributes: {
				row: { class: 'mb-6' },
				container: { class: 'space-y-6' }
			},
			fields: {
				'@global': {
					attributes: {
						label: { class: 'block text-sm font-medium text-gray-300 mb-2' },
						input: { class: 'w-full px-3 py-2 border border-gray-700 bg-gray-800 text-gray-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent' },
						instructions: { class: 'text-sm text-gray-500 mt-1' },
						error: { class: 'text-sm text-red-400 mt-1' }
					}
				},
				'@checkbox': {
					attributes: {
						input: { class: 'focus:ring-red-500 h-8 w-8 text-red-600 border-red-500 bg-gray-800 rounded' },
						label: { class: '!text-lg text-red-500 font-medium ml-2' },
						instructions: { class: 'text-base text-red-400 mt-1' }
					}
				},

				'@submit': {
					attributes: {
						container: { class: 'mt-8' },
						input: { class: 'w-full bg-green-600 text-white py-3 px-4 rounded-lg hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 focus:ring-offset-gray-900 transition-colors font-medium' }
					}
				},
				'@stripe': {
					attributes: {
						input: { class: 'w-full px-3 py-2 border border-gray-700 bg-gray-800 text-gray-100 rounded-lg' }
					}
				}
			}
		}) }}

		<div class="mt-6 text-center">
			<p class="text-gray-400">Already have an account? <a href="/login" class="text-blue-400 hover:text-blue-300 font-medium">Sign in</a></p>
		</div>
	</div>
</div>
{% endblock %}
