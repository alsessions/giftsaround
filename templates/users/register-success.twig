{% extends "_layouts/base.twig" %}

{% set title = "Registration Successful" %}

{% block content %}
<div class="max-w-2xl mx-auto mt-8 mb-16">
    <div class="bg-gray-900 rounded-lg shadow-md p-8 text-center border border-gray-800">
        <div class="mb-6">
            <div class="mx-auto w-16 h-16 bg-green-900/50 rounded-full flex items-center justify-center mb-4 border border-green-700">
                <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            <h1 class="text-3xl font-bold text-green-400 mb-2">Welcome to {{ siteName }}!</h1>
            <p class="text-xl text-gray-300">Your account has been created successfully</p>
        </div>

        <div class="bg-amber-900/20 border border-amber-800 rounded-lg p-6 mb-8">
            <div class="flex items-center justify-center mb-3">
                <svg class="w-8 h-8 text-amber-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <h2 class="text-lg font-semibold text-amber-300">Check Your Email</h2>
            </div>
            <p class="text-amber-300 mb-3">
                <strong>Important:</strong> To activate your account, you need to verify your email address.
            </p>
            <p class="text-amber-400 text-sm">
                We've sent a confirmation email with an activation link. Please check your inbox (and spam folder) and click the link to complete your registration.
            </p>
        </div>

        <div class="bg-blue-900/20 border border-blue-800 rounded-lg p-6 mb-8">
            <h2 class="text-lg font-semibold text-blue-300 mb-2">Once Your Account is Activated:</h2>
            <ul class="text-left text-blue-400 space-y-2">
                <li class="flex items-start">
                    <svg class="w-5 h-5 text-blue-500 mt-0.5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <span>Complete your profile information</span>
                </li>
                <li class="flex items-start">
                    <svg class="w-5 h-5 text-blue-500 mt-0.5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <span>Explore our business directory</span>
                </li>
                <li class="flex items-start">
                    <svg class="w-5 h-5 text-blue-500 mt-0.5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                    </svg>
                    <span>Start connecting with our community</span>
                </li>
            </ul>
        </div>

        <div class="space-y-4">
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/account" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-lg text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 focus:ring-offset-gray-900 transition-colors">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                    Go to My Account
                </a>

                <a href="/business" class="inline-flex items-center justify-center px-6 py-3 border border-gray-600 text-base font-medium rounded-lg text-gray-300 bg-gray-800 hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-gray-900 transition-colors">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                    Browse Businesses
                </a>
            </div>

            <div class="pt-4 border-t border-gray-800">
                <a href="/" class="text-gray-500 hover:text-gray-300 transition-colors">
                    ← Back to Home
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
